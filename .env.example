# TranquilAI Spring Backend - Environment Variables
# Copy this file to .env and fill in local or deployment values.
# Do not commit real secrets.

# JWT Secret (must be at least 256 bits / 32 characters)
JWT_SECRET=replace_with_long_random_secret

# Gemini API
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Database (PostgreSQL)
SPRING_POSTGRESQL_USERNAME=tranquilai
SPRING_POSTGRESQL_PASSWORD=tranquilai_secret

# Database (MongoDB)
SPRING_MONGODB_USERNAME=tranquilai
SPRING_MONGODB_PASSWORD=tranquilai_secret
SPRING_MONGODB_URI=mongodb://tranquilai:tranquilai_secret@mongodb:27017/tranquilai_ai?authSource=admin

# Database admin UIs
PGADMIN_DEFAULT_EMAIL=admin@tranquilai.dev
PGADMIN_DEFAULT_PASSWORD=admin_secret
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=admin_secret

# Redis
SPRING_REDIS_PASSWORD=tranquilai_secret

# RabbitMQ
SPRING_RABBITMQ_USERNAME=tranquilai
SPRING_RABBITMQ_PASSWORD=tranquilai_secret

# Email (local dev uses Mailpit)
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
EMAIL_FROM=noreply@tranquilai.cloud

# Google Play subscriptions
GOOGLE_PLAY_PACKAGE_NAME=com.tranquilai.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Firebase / FCM
FIREBASE_SERVICE_ACCOUNT_JSON=

# Internal service key (shared secret for service-to-service calls)
INTERNAL_SERVICE_KEY=replace_with_long_random_internal_secret

# Subscription limits
SUBSCRIPTION_TRIAL_DAYS=7
SUBSCRIPTION_FREE_AI_CHAT_LIMIT=3
SUBSCRIPTION_FREE_JOURNAL_LIMIT=2
